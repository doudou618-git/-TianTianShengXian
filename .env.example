# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database
DB_NAME=tiantian
DB_USER=root
DB_PASSWORD=your-password-here
DB_HOST=localhost
DB_PORT=3306

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Celery 配置（使用 Redis 的不同数据库）
CELERY_BROKER_URL=redis://127.0.0.1:6379/3
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/4

# Email (QQ邮箱SMTP配置 - 发送真实邮件)
# 注意：EMAIL_HOST_PASSWORD 是QQ邮箱授权码，不是QQ密码
# 获取方式：QQ邮箱网页版 → 设置 → 账户 → 开启IMAP/SMTP服务 → 生成授权码
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your-email@qq.com
EMAIL_HOST_PASSWORD=your-email-auth-code
DEFAULT_FROM_EMAIL=天天生鲜 <your-email@qq.com>

# 2. 应用密钥：点击"设置" → 生成密钥 → 复制应用公钥和应用私钥
